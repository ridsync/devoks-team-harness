{
  "_note": "수동 참조용 예시입니다. 플러그인은 공유 MCP를 번들하지 않으므로 user scope에 1회 설치해야 합니다. 자동 설치는 /devoks-setup-mcp 커맨드를, 방식·prefix 규칙은 docs/mcp-setup-guide.md 를 참고하세요.",
  "mcpServers": {
    "chrome-devtools-attach": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9269"
      ],
      "type": "stdio",
      "_comment": "devoks-browser 스킬 필수. Chrome을 --remote-debugging-port=9269 로 실행해야 함."
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "type": "stdio",
      "_comment": "라이브러리 문서 조회 (선택). devoks-feature/code 스킬에서 사용."
    },
    "serena": {
      "command": "uvx",
      "args": [
        "serena@latest",
        "--project",
        "/path/to/your/project"
      ],
      "type": "stdio",
      "_comment": "심볼 단위 코드 편집. devoks-code 커맨드 권장. --project 경로를 실제 프로젝트 경로로 교체."
    }
  }
}
