{
  "description": "DevOks 프로젝트 초기화 상태와 권장 MCP 구성을 SessionStart에 점검한다.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-setup-state.sh",
            "args": [],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
